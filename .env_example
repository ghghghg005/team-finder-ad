# Django
DJANGO_SECRET_KEY=change_for_safety
DJANGO_DEBUG=True
# Comma-separated list of allowed hosts.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Set to True to use a local SQLite database during development
# (handy when a PostgreSQL driver cannot be built locally).
# Leave it False / unset to use PostgreSQL (the default for this project).
USE_SQLITE=False

# PostgreSQL
POSTGRES_DB=team_finder
POSTGRES_USER=team_finder
POSTGRES_PASSWORD=team_finder
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Which set of HTML templates to use: 1, 2 or 3 (this project implements variant 1).
TASK_VERSION=1
